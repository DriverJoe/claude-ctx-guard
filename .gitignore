# --- OS / editor cruft ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini
*~
*.swp
*.swo
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# --- Backups / temp files produced at install/uninstall time ---
# (These land in the user's ~/.claude, not the repo, but ignore them anyway
#  in case someone runs the installer from inside a checkout.)
*.bak
*.orig
*.tmp
*.tmp.*
.*.json.tmp.*

# --- Runtime state that must never be committed ---
# The token-bridge state dir + error log live under ~/.claude/ctx-state,
# but guard against a stray local copy.
ctx-state/
*.guard.json
guard-errors.log

# --- Shell tooling ---
*.log
shellcheck-report.*

# --- Local scratch ---
/tmp/
/scratch/

